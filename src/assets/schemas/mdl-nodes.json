{
  "$schema": "https://openkotor.com/schemas/binary-format-fragment.schema.json",
  "types": {
    "Node Type": {
      "kind": "enum",
      "base": "u16",
      "description": "Node type flags. Check in this order when reading: Emitter(4), Light(2), Skin(64), Dangly(256), Saber(2048), AABB(512), Anim(128)=skip 56 bytes and do not add to tree, Mesh(32), Reference(16), else Header(1). Multiple bits can be set (e.g. Skin+Mesh).",
      "values": {
        "Header": 1,
        "Light": 2,
        "Emitter": 4,
        "Camera": 8,
        "Reference": 16,
        "Mesh": 32,
        "Skin": 64,
        "Anim": 128,
        "Dangly": 256,
        "AABB": 512,
        "Saber": 2048
      }
    },
    "Emitter Flags": {
      "kind": "bitflags",
      "base": "u32",
      "description": "Emitter node Flags field. P2P=point-to-point, P2P_SEL=selection, AFFECTED_WIND, TINTED, BOUNCE, RANDOM, INHERIT, INHERIT_VEL, INHERIT_LOCAL, SPLAT, INHERIT_PART, DEPTH_TEXTURE.",
      "bits": {
        "P2P": 1,
        "P2P_SEL": 2,
        "AFFECTED_WIND": 4,
        "TINTED": 8,
        "BOUNCE": 16,
        "RANDOM": 32,
        "INHERIT": 64,
        "INHERIT_VEL": 128,
        "INHERIT_LOCAL": 256,
        "SPLAT": 512,
        "INHERIT_PART": 1024,
        "DEPTH_TEXTURE": 2048,
        "_13": 4096,
        "_2000": 8192,
        "_3000": 16384,
        "_4000": 32768
      }
    },
    "Base Node": {
      "kind": "struct",
      "description": "Common node header. Node Type determines extension. Name from Names[Node Position]. Child offsets at Child Array Definition; controllers at Controller Array Definition.",
      "fields": [
        { "name": "Node Type", "type": "Node Type", "description": "Node type flags. Dispatch order: Emitter(4), Light(2), Skin(64), Dangly(256), Saber(2048), AABB(512), Anim(128)=skip 56 bytes, Mesh(32), Reference(16), else Header(1). Offset 0, 2 bytes." },
        { "name": "Supernode", "type": "u16", "description": "Offset 2, 2 bytes." },
        { "name": "Node Position", "type": "u16", "description": "Index into Names. Offset 4, 2 bytes." },
        { "name": "Padding", "type": "u16", "description": "Offset 6, 2 bytes." },
        { "name": "Offset To Root", "type": "u32", "description": "Offset 8, 4 bytes." },
        { "name": "Offset To Parent", "type": "u32", "description": "Offset 12, 4 bytes." },
        { "name": "Position X", "type": "f32", "description": "Offset 16, 4 bytes." },
        { "name": "Position Y", "type": "f32", "description": "Offset 20, 4 bytes." },
        { "name": "Position Z", "type": "f32", "description": "Offset 24, 4 bytes." },
        { "name": "Quaternion W", "type": "f32", "description": "Offset 28, 4 bytes." },
        { "name": "Quaternion X", "type": "f32", "description": "Offset 32, 4 bytes." },
        { "name": "Quaternion Y", "type": "f32", "description": "Offset 36, 4 bytes." },
        { "name": "Quaternion Z", "type": "f32", "description": "Offset 40, 4 bytes." },
        { "name": "Child Array Definition", "type": "Array Definition", "description": "Offset 44, 12 bytes." },
        { "name": "Controller Array Definition", "type": "Array Definition", "description": "Offset 56, 12 bytes." },
        { "name": "Controller Data Array Definition", "type": "Array Definition", "description": "Offset 68, 12 bytes." }
      ]
    },
    "BaseNode": {
      "kind": "struct",
      "description": "After Base Node when Node Type has Mesh bit. Faces, bounds, textures, MDX offsets and bitmap, vertex count.",
      "fields": [
        { "name": "Function Pointer 0", "type": "u32", "description": "Offset 72, 4 bytes." },
        { "name": "Function Pointer 1", "type": "u32", "description": "Offset 76, 4 bytes." },
        { "name": "Face Array Definition", "type": "Array Definition", "description": "Offset 80, 12 bytes." },
        { "name": "Bounding Box Min X", "type": "f32", "description": "Offset 92, 4 bytes." },
        { "name": "Bounding Box Min Y", "type": "f32", "description": "Offset 96, 4 bytes." },
        { "name": "Bounding Box Min Z", "type": "f32", "description": "Offset 100, 4 bytes." },
        { "name": "Bounding Box Max X", "type": "f32", "description": "Offset 104, 4 bytes." },
        { "name": "Bounding Box Max Y", "type": "f32", "description": "Offset 108, 4 bytes." },
        { "name": "Bounding Box Max Z", "type": "f32", "description": "Offset 112, 4 bytes." },
        { "name": "Radius", "type": "f32", "description": "Offset 116, 4 bytes." },
        { "name": "Average X", "type": "f32", "description": "Offset 120, 4 bytes." },
        { "name": "Average Y", "type": "f32", "description": "Offset 124, 4 bytes." },
        { "name": "Average Z", "type": "f32", "description": "Offset 128, 4 bytes." },
        { "name": "Diffuse R", "type": "f32", "description": "Offset 132, 4 bytes." },
        { "name": "Diffuse G", "type": "f32", "description": "Offset 136, 4 bytes." },
        { "name": "Diffuse B", "type": "f32", "description": "Offset 140, 4 bytes." },
        { "name": "Ambient R", "type": "f32", "description": "Offset 144, 4 bytes." },
        { "name": "Ambient G", "type": "f32", "description": "Offset 148, 4 bytes." },
        { "name": "Ambient B", "type": "f32", "description": "Offset 152, 4 bytes." },
        { "name": "Transparency Hint", "type": "u32", "description": "Offset 156, 4 bytes." },
        { "name": "Texture Map 1", "type": { "kind": "string", "length": 32 }, "description": "Offset 160, 32 bytes." },
        { "name": "Texture Map 2", "type": { "kind": "string", "length": 32 }, "description": "Offset 192, 32 bytes." },
        { "name": "Texture Map 3", "type": { "kind": "string", "length": 12 }, "description": "Offset 224, 12 bytes." },
        { "name": "Texture Map 4", "type": { "kind": "string", "length": 12 }, "description": "Offset 236, 12 bytes." },
        { "name": "Index Count Array Definition", "type": "Array Definition", "description": "Offset 248, 12 bytes." },
        { "name": "Vertex Location Array Definition", "type": "Array Definition", "description": "Offset 260, 12 bytes." },
        { "name": "Inverted Count Array Definition", "type": "Array Definition", "description": "Offset 272, 12 bytes." },
        { "name": "Inverted Count Array Definition Duplicate", "type": "Array Definition", "description": "Offset 284, 12 bytes." },
        { "name": "Saber Bytes", "type": { "kind": "bytes", "length": 8 }, "description": "Offset 296, 8 bytes." },
        { "name": "Animate UV", "type": "u32", "description": "Offset 304, 4 bytes." },
        { "name": "UV Direction X", "type": "f32", "description": "Offset 308, 4 bytes." },
        { "name": "UV Direction Y", "type": "f32", "description": "Offset 312, 4 bytes." },
        { "name": "UV Jitter", "type": "f32", "description": "Offset 316, 4 bytes." },
        { "name": "UV Jitter Speed", "type": "f32", "description": "Offset 320, 4 bytes." },
        { "name": "MDX Data Size", "type": "u32", "description": "Per-vertex stride in MDX. Offset 324, 4 bytes." },
        { "name": "MDX Data Bitmap", "type": "MDXFlag", "description": "VERTEX=1, UV1=2, UV2=4, NORMAL=32, COLOR=64, TANGENT1-4. Offset 328, 4 bytes." },
        { "name": "MDX Vertex Offset", "type": "u32", "description": "Offset 332, 4 bytes." },
        { "name": "MDX Vertex Normals Offset", "type": "u32", "description": "Offset 336, 4 bytes." },
        { "name": "MDX Vertex Colors Offset", "type": "u32", "description": "Offset 340, 4 bytes." },
        { "name": "MDX UV Offset 1", "type": "s32", "description": "Offset 344, 4 bytes." },
        { "name": "MDX UV Offset 2", "type": "s32", "description": "Offset 348, 4 bytes." },
        { "name": "MDX UV Offset 3", "type": "s32", "description": "Offset 352, 4 bytes." },
        { "name": "MDX UV Offset 4", "type": "s32", "description": "Offset 356, 4 bytes." },
        { "name": "Offset To MDX Tangent 1", "type": "s32", "description": "Offset 360, 4 bytes." },
        { "name": "Offset To MDX Tangent 2", "type": "s32", "description": "Offset 364, 4 bytes." },
        { "name": "Offset To MDX Tangent 3", "type": "s32", "description": "Offset 368, 4 bytes." },
        { "name": "Offset To MDX Tangent 4", "type": "s32", "description": "Offset 372, 4 bytes." },
        { "name": "Vertices Count", "type": "u16", "description": "Offset 376, 2 bytes." },
        { "name": "Texture Count", "type": "u16", "description": "Offset 378, 2 bytes." },
        { "name": "Has Lightmap", "type": "u8", "description": "Offset 380, 1 byte." },
        { "name": "Rotate Texture", "type": "u8", "description": "Offset 381, 1 byte." },
        { "name": "Background Geometry", "type": "u8", "description": "Offset 382, 1 byte." },
        { "name": "Flag Shadow", "type": "u8", "description": "Offset 383, 1 byte." },
        { "name": "Beaming", "type": "u8", "description": "Offset 384, 1 byte." },
        { "name": "Flag Render", "type": "u8", "description": "Offset 385, 1 byte." },
        { "name": "Dirt Enabled", "type": "u8", "description": "K2/TSL only; present only when engine is K2. Offset 386, 1 byte." },
        { "name": "TSL Padding 1", "type": "u8", "description": "K2/TSL only. Offset 387, 1 byte." },
        { "name": "Dirt Texture", "type": "u16", "description": "K2/TSL only. Offset 388, 2 bytes." },
        { "name": "Dirt Coord Space", "type": "u16", "description": "K2/TSL only. Offset 390, 2 bytes." },
        { "name": "Hide In Holograms", "type": "u8", "description": "K2/TSL only. Offset 392, 1 byte." },
        { "name": "TSL Padding 2", "type": "u8", "description": "K2/TSL only. Offset 393, 1 byte." },
        { "name": "Unknown 2", "type": "u16", "description": "Offset 386 (K1) or 394 (K2), 2 bytes." },
        { "name": "Total Area", "type": "f32", "description": "Offset 388 (K1) or 396 (K2), 4 bytes." },
        { "name": "Unknown 4", "type": "u32", "description": "Offset 392 (K1) or 400 (K2), 4 bytes." },
        { "name": "MDX Node Data Offset", "type": "u32", "description": "Offset 396 (K1) or 404 (K2), 4 bytes." },
        { "name": "Vertex Coordinates Offset", "type": "u32", "description": "Offset 400 (K1) or 408 (K2), 4 bytes." }
      ]
    },
    "Skin Node Extension": {
      "kind": "struct",
      "description": "After Mesh Node when Node Type has Skin bit. Bone weights/indices in MDX; bone map and inverse bind pose in MDL.",
      "fields": [
        { "name": "Weights Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "MDX Bone Weight Offset", "type": "u32", "description": "4 bytes." },
        { "name": "MDX Bone Index Offset", "type": "u32", "description": "4 bytes." },
        { "name": "Bone Map Offset", "type": "u32", "description": "4 bytes." },
        { "name": "Bone Map Count", "type": "u32", "description": "4 bytes." },
        { "name": "Bone Quaternion Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Bone Position Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Bone Constants Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Bone Parts", "type": { "kind": "bytes", "length": 34 }, "description": "17* u16. 34 bytes." }
      ]
    },
    "Emitter Node Extension": {
      "kind": "struct",
      "description": "After Base Node when Node Type has Emitter bit. Particle params and resource refs.",
      "fields": [
        { "name": "Dead Space", "type": "f32", "description": "4 bytes." },
        { "name": "Blast Radius", "type": "f32", "description": "4 bytes." },
        { "name": "Blast Length", "type": "f32", "description": "4 bytes." },
        { "name": "Branch Count", "type": "u32", "description": "4 bytes." },
        { "name": "Control Point Smoothing", "type": "f32", "description": "4 bytes." },
        { "name": "Grid X", "type": "u32", "description": "4 bytes." },
        { "name": "Grid Y", "type": "u32", "description": "4 bytes." },
        { "name": "Space Type", "type": "u32", "description": "4 bytes." },
        { "name": "Update Mode", "type": { "kind": "string", "length": 32 }, "description": "32 bytes." },
        { "name": "Render Mode", "type": { "kind": "string", "length": 32 }, "description": "32 bytes." },
        { "name": "Blend Mode", "type": { "kind": "string", "length": 32 }, "description": "32 bytes." },
        { "name": "Texture ResRef", "type": { "kind": "string", "length": 32 }, "description": "32 bytes." },
        { "name": "Chunk ResRef", "type": { "kind": "string", "length": 16 }, "description": "16 bytes." },
        { "name": "Two Sided Tex", "type": "u32", "description": "4 bytes." },
        { "name": "Loop", "type": "u32", "description": "4 bytes." },
        { "name": "Render Order", "type": "u16", "description": "2 bytes." },
        { "name": "Padding 1", "type": "u16", "description": "2 bytes." },
        { "name": "Flags", "type": "Emitter Flags", "description": "Emitter flags (P2P, wind, bounce, etc.). 4 bytes. See Emitter Flags bitflags." }
      ]
    },
    "Light Node Extension": {
      "kind": "struct",
      "description": "After Base Node when Node Type has Light bit.",
      "fields": [
        { "name": "Flare Radius", "type": "f32", "description": "4 bytes." },
        { "name": "Unknown", "type": { "kind": "bytes", "length": 12 }, "description": "12 bytes." },
        { "name": "Flare Sizes Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Flare Positions Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Flare Color Shifts Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Flare Textures Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Light Priority", "type": "u32", "description": "4 bytes." },
        { "name": "Ambient Flag", "type": "u32", "description": "4 bytes." },
        { "name": "Dynamic Flag", "type": "u32", "description": "4 bytes." },
        { "name": "Affect Dynamic Flag", "type": "u32", "description": "4 bytes." },
        { "name": "Shadow Flag", "type": "u32", "description": "4 bytes." },
        { "name": "Generate Flare Flag", "type": "u32", "description": "4 bytes." },
        { "name": "Fading Light Flag", "type": "u32", "description": "4 bytes." }
      ]
    },
    "Reference Node Extension": {
      "kind": "struct",
      "description": "After Base Node when Node Type has Reference bit.",
      "fields": [
        { "name": "Model Name", "type": { "kind": "string", "length": 32 }, "description": "32 bytes." },
        { "name": "Reattachable", "type": "s32", "description": "4 bytes." }
      ]
    },
    "AABB Node Extension": {
      "kind": "struct",
      "description": "After Mesh Node when Node Type has AABB bit.",
      "fields": [
        { "name": "Root AABB Node Offset", "type": "u32", "description": "4 bytes." }
      ]
    },
    "AABB Tree Node": {
      "kind": "struct",
      "description": "Recursive AABB node. 40 bytes.",
      "fields": [
        { "name": "Min X", "type": "f32", "description": "Offset 0, 4 bytes." },
        { "name": "Min Y", "type": "f32", "description": "Offset 4, 4 bytes." },
        { "name": "Min Z", "type": "f32", "description": "Offset 8, 4 bytes." },
        { "name": "Max X", "type": "f32", "description": "Offset 12, 4 bytes." },
        { "name": "Max Y", "type": "f32", "description": "Offset 16, 4 bytes." },
        { "name": "Max Z", "type": "f32", "description": "Offset 20, 4 bytes." },
        { "name": "Left Node Offset", "type": "s32", "description": "Offset 24, 4 bytes." },
        { "name": "Right Node Offset", "type": "s32", "description": "Offset 28, 4 bytes." },
        { "name": "Face Index", "type": "s32", "description": "Offset 32, 4 bytes." },
        { "name": "Most Significant Plane", "type": "s32", "description": "Offset 36, 4 bytes." }
      ]
    },
    "Dangly Node Extension": {
      "kind": "struct",
      "description": "After Mesh Node when Node Type has Dangly bit.",
      "fields": [
        { "name": "Constraint Array Definition", "type": "Array Definition", "description": "12 bytes." },
        { "name": "Dangly Displacement", "type": "f32", "description": "4 bytes." },
        { "name": "Dangly Tightness", "type": "f32", "description": "4 bytes." },
        { "name": "Dangly Period", "type": "f32", "description": "4 bytes." },
        { "name": "Dangly MDL Offset", "type": "u32", "description": "4 bytes." }
      ]
    },
    "Saber Node Extension": {
      "kind": "struct",
      "description": "After Mesh Node when Node Type has Saber bit.",
      "fields": [
        { "name": "Offset To Saber Verts", "type": "u32", "description": "4 bytes." },
        { "name": "Offset To Saber UVs", "type": "u32", "description": "4 bytes." },
        { "name": "Offset To Saber Normals", "type": "u32", "description": "4 bytes." },
        { "name": "Inv Count 1", "type": "u32", "description": "4 bytes." },
        { "name": "Inv Count 2", "type": "u32", "description": "4 bytes." }
      ]
    },
    "Face Record": {
      "kind": "struct",
      "description": "One mesh face. 32 bytes.",
      "fields": [
        { "name": "Normal X", "type": "f32", "description": "Offset 0, 4 bytes." },
        { "name": "Normal Y", "type": "f32", "description": "Offset 4, 4 bytes." },
        { "name": "Normal Z", "type": "f32", "description": "Offset 8, 4 bytes." },
        { "name": "Distance", "type": "f32", "description": "Offset 12, 4 bytes." },
        { "name": "Material Index", "type": "u32", "description": "Offset 16, 4 bytes." },
        { "name": "Adjacent 0", "type": "s16", "description": "Offset 20, 2 bytes." },
        { "name": "Adjacent 1", "type": "s16", "description": "Offset 22, 2 bytes." },
        { "name": "Adjacent 2", "type": "s16", "description": "Offset 24, 2 bytes." },
        { "name": "Vertex Index A", "type": "u16", "description": "Offset 26, 2 bytes." },
        { "name": "Vertex Index B", "type": "u16", "description": "Offset 28, 2 bytes." },
        { "name": "Vertex Index C", "type": "u16", "description": "Offset 30, 2 bytes." }
      ]
    },
    "Face Array Layout": {
      "kind": "struct",
      "description": "Per-mesh face list (see BaseNode Face Array Definition). At modelDataOffset + Face Array Definition.offset: Count x Face Record (32 bytes each). Faces define triangles (Vertex Index A/B/C) and adjacency (Adjacent 0/1/2).",
      "fields": []
    },
    "Index Array Layout": {
      "kind": "struct",
      "description": "Per-mesh index list (see BaseNode Index Count Array Definition). At modelDataOffset + Index Count Array Definition.offset: array of vertex indices, typically u16, length given by Count. Used as triangle list for rendering (every three indices form one triangle).",
      "fields": []
    },
    "Node Type Dispatch": {
      "kind": "struct",
      "description": "When reading a node at a given offset (relative to model data start), peek Node Type (u16). Dispatch in this order (first match wins): (1) If (NodeType & 0x0004)==0x0004 then Emitter: read Base Node (80 bytes) then Emitter Node Extension (224 bytes). (2) If (NodeType & 0x0002)==0x0002 then Light: Base Node then Light Node Extension (76 bytes). (3) If (NodeType & 0x0040)==0x0040 then Skin: Base Node then Mesh Node Extension (332 bytes K1 / 340 bytes K2) then Skin Node Extension (86 bytes). (4) If (NodeType & 0x0100)==0x0100 then Dangly: Base Node then Mesh Extension then Dangly Node Extension (28 bytes). (5) If (NodeType & 0x0800)==0x0800 then Saber: Base Node then Mesh Extension then Saber Node Extension (20 bytes). (6) If (NodeType & 0x0200)==0x0200 then AABB: Base Node then Mesh Extension then AABB Node Extension (4 bytes). (7) If (NodeType & 0x0080)==0x0080 then Anim: skip 56 bytes total (do not read base node; no children); return no node. (8) If (NodeType & 0x0020)==0x0020 then Mesh: Base Node then Mesh Node Extension. (9) If (NodeType & 0x0010)==0x0010 then Reference: Base Node then Reference Node Extension (36 bytes). (10) Else Header: Base Node only (80 bytes). After reading the node, read Child Array Definition and then the array of child offsets (count * u32) at modelDataOffset + Child Array Definition.offset; recurse for each child. Then read Controller Array Definition and Controller Data Array Definition; controller records at modelDataOffset + Controller Array Definition.offset (count * 16 bytes each).",
      "fields": []
    },
    "MDX Vertex Layout": {
      "kind": "struct",
      "description": "Per-vertex data in the MDX file. Vertex i starts at byte offset (MDXNodeDataOffset + i * MDXDataSize) within the MDX buffer. MDX Data Bitmap determines which components exist. If VERTEX(0x0001): at +MDXVertexOffset read 3* float (position). If NORMAL(0x0020): at +MDXVertexNormalsOffset read 3* float. If COLOR(0x0040): at +MDXVertexColorsOffset read 3* float. If UV1(0x0002): at +MDXUVOffset1 read 2* float. If UV2(0x0004): at +MDXUVOffset2 read 2* float. If UV3/UV4: at MDXUVOffset3/4 read 2* float each. If TANGENT1(0x0080): at +offsetToMdxTangent1 read tangent (3 float), bitangent (3 float), normal (3 float). Same for TANGENT2-4. Skin nodes: at +MDXBoneWeightOffset read 4* float (weights); at +MDXBoneIndexOffset read 4* float (bone indices). All offsets are relative to the start of the vertex's MDXDataSize-byte block.",
      "fields": []
    }
  }
}
